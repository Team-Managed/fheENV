SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PRIVATE_KEY=0xyour_deployer_private_key
NEXT_PUBLIC_REGISTRY_ADDRESS=0xb9a29d0Cfb402d91c6f70eF117758C118f00F5B2
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Server-side only (used by /api/ipfs route — never exposed to browser)
PINATA_JWT=

# ── CLI env vars ──────────────────────────────────────────────────────────────

# RPC / chain overrides (optional — defaults come from .fheenv.json)
FHEENV_RPC_URL=

# Pinata JWT override for CI (keeps .fheenv.json secret-free)
FHEENV_PINATA_JWT=

# ── Scheduled rotation — Lit Protocol OIDC signing (Finding F-01) ────────────
# Run `ts-node scripts/setup-lit-rotator.ts` to generate these values.

# IPFS CID of lit-actions/rotator-signer.js — public, not a secret
FHEENV_LIT_ACTION_CID=

# Lit Chipotle API usage key — meters API calls, NOT the signing key
FHEENV_LIT_API_KEY=

# Optional: override the Lit API endpoint (e.g. for self-hosted nodes)
FHEENV_LIT_API_URL=

# GitHub OIDC JWT — set automatically by the rotate-scheduled.yml workflow;
# do not set manually in production
GITHUB_OIDC_JWT=

# ── Audit / observability ─────────────────────────────────────────────────────

# PostHog server-side key — enables CLI rotation event capture
# Events sent: fheenv_key_rotated, fheenv_cli_push, fheenv_cli_pull, etc.
# distinctId is project-{projectId} — no wallet addresses are sent
POSTHOG_API_KEY=

# Optional: override PostHog ingest host (e.g. EU region or self-hosted)
POSTHOG_HOST=

# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# PostHog browser key — enables page view / reach analytics in the dashboard
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
